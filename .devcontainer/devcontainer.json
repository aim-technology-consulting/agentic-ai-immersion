{
    "name": "Agentic AI Immersion Day",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    
    "features": {
        "ghcr.io/devcontainers/features/azure-cli:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/azure/azure-dev/azd:0.2.0": {}
    },
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-keymap",
                "ms-toolsai.jupyter-renderers",
                "ms-azuretools.vscode-azurefunctions",
                "ms-azuretools.vscode-docker",
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-vscode.azure-account",
                "redhat.vscode-yaml",
                "ms-python.black-formatter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.terminal.activateEnvironment": true,
                "jupyter.askForKernelRestart": false,
                "editor.formatOnSave": true,
                "python.formatting.provider": "none",
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter"
                },
                "python.analysis.indexing": false,
                "python.analysis.diagnosticMode": "openFilesOnly",
                "python.analysis.exclude": [
                    "**/site-packages/**",
                    "**/node_modules/**",
                    "**/__pycache__/**"
                ],
                "python.analysis.typeCheckingMode": "basic",
                "python.analysis.memory.keepLibraryAst": false,
                "python.analysis.autoImportCompletions": false,
                "python.analysis.packageIndexDepths": [
                    {"name": "", "depth": 1}
                ],
                "github.copilot.enable": {
                    "*": true,
                    "plaintext": true,
                    "markdown": true,
                    "python": true
                },
                "github.copilot.editor.enableAutoCompletions": true,
                "github.copilot.advanced": {
                    "debug.overrideEngine": "",
                    "debug.testOverrideProxyUrl": "",
                    "debug.overrideProxyUrl": ""
                },
                "files.exclude": {
                    "**/__pycache__": true,
                    "**/.pytest_cache": true,
                    "**/*.pyc": true
                },
                "search.exclude": {
                    "**/site-packages": true,
                    "**/.venv": true,
                    "**/venv": true
                },
                "files.watcherExclude": {
                    "**/__pycache__/**": true,
                    "**/site-packages/**": true,
                    "**/.venv/**": true
                }
            }
        }
    },
    
    "postCreateCommand": "echo 'Container ready!'",
    
    "updateContentCommand": "pip install --upgrade --no-cache-dir -r requirements.txt",
    
    "containerEnv": {
        "PYTHONDONTWRITEBYTECODE": "1",
        "PYTHONUNBUFFERED": "1"
    },
    
    "runArgs": [
        "--memory=16g",
        "--memory-swap=24g",
        "--cpus=4"
    ],
    
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.azure,target=/home/vscode/.azure,type=bind,consistency=cached"
    ],
    
    "remoteUser": "vscode",
    
    "forwardPorts": [8888],
    
    "portsAttributes": {
        "8888": {
            "label": "Jupyter",
            "onAutoForward": "notify"
        }
    }
}
